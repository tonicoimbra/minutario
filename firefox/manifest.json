{
  "manifest_version": 2,
  "name": "Minutário para Firefox",
  "version": "1.1.0",
  "description": "Expanda atalhos de texto em modelos HTML ricos em qualquer página do navegador.",
  "author": "Elvertoni Coimbra",
  "permissions": [
    "storage",
    "clipboardWrite",
    "clipboardRead",
    "alarms",
    "tabs",
    "<all_urls>",
    "https://*.supabase.co/*"
  ],
  "background": {
    "scripts": [
      "lib/supabase.min.js",
      "shared/browser-compat.js",
      "shared/config.js",
      "shared/db.js",
      "shared/api.js",
      "shared/sync.js",
      "background.js"
    ],
    "persistent": false
  },
  "browser_action": {
    "default_popup": "popup/popup.html",
    "default_title": "Minutário"
  },
  "commands": {
    "open-quick-access": {
      "suggested_key": {
        "default": "Ctrl+Shift+K",
        "mac": "Command+Shift+K"
      },
      "description": "Abrir consulta rápida de minutas"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "shared/browser-compat.js",
        "shared/config.js",
        "shared/db.js",
        "shared/api.js",
        "shared/sync.js",
        "content.js"
      ],
      "run_at": "document_idle",
      "all_frames": true,
      "match_about_blank": true
    }
  ],
  "web_accessible_resources": [
    "dashboard/dashboard.html",
    "dashboard/dashboard.js",
    "dashboard/dashboard.css",
    "dashboard/index.html",
    "password-reset/password-reset.html",
    "password-reset/password-reset.js",
    "quick-access/*",
    "shared/*",
    "lib/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "minutario-firefox@example.com",
      "strict_min_version": "109.0"
    }
  }
}
