{
  "name": "minutario-extension",
  "author": "Elvertoni Coimbra",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "test": "node --test tests/*.test.js",
    "check": "node --check background.js content.js popup/popup.js shared/api.js shared/sync.js dashboard/sync/supabase.js",
    "pack:chrome": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/pack-chrome.ps1",
    "pack:firefox": "npx web-ext build --source-dir . --artifacts-dir dist/firefox --overwrite-dest --ignore-files \"tests/*\" \"docs/*\" \"supabase/*\" \"scripts/*\" \"node_modules/*\" \".codex/*\" \".superpowers/*\" \"dist/*\" \"*.md\"",
    "sign:firefox": "npx web-ext sign --source-dir . --artifacts-dir dist/firefox --api-key %AMO_JWT_ISSUER% --api-secret %AMO_JWT_SECRET% --ignore-files \"tests/*\" \"docs/*\" \"supabase/*\" \"scripts/*\" \"node_modules/*\" \".codex/*\" \".superpowers/*\" \"dist/*\" \"*.md\"",
    "version:bump:patch": "node scripts/bump-version.js patch",
    "version:bump:minor": "node scripts/bump-version.js minor",
    "version:bump:major": "node scripts/bump-version.js major",
    "release:pilot": "npm run test && npm run check && npm run pack:chrome && npm run pack:firefox",
    "release:pilot:full:patch": "npm run version:bump:patch && npm run release:pilot",
    "release:pilot:full:minor": "npm run version:bump:minor && npm run release:pilot"
  },
  "devDependencies": {
    "jsdom": "^26.1.0",
    "web-ext": "^8.10.0"
  }
}
