{
  "manifest_version": 3,
  "name": "Minutário",
  "version": "1.1.0",
  "description": "Expanda atalhos de texto em modelos HTML ricos em qualquer página do navegador.",
  "author": "Elvertoni Coimbra",
  "browser_specific_settings": {
    "gecko": {
      "id": "minutario@elvertoni.coimbra"
    }
  },
  "permissions": ["storage", "clipboardWrite", "clipboardRead", "alarms", "tabs", "debugger"],
  "host_permissions": [
    "<all_urls>",
    "https://*.supabase.co/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Minutário"
  },
  "commands": {
    "open-quick-access": {
      "suggested_key": {
        "default": "Ctrl+Shift+K",
        "mac": "Command+Shift+K"
      },
      "description": "Abrir consulta rápida de minutas"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "shared/browser-compat.js",
        "shared/config.js",
        "shared/db.js",
        "shared/api.js",
        "shared/sync.js",
        "content.js"
      ],
      "run_at": "document_idle",
      "all_frames": true,
      "match_about_blank": true,
      "match_origin_as_fallback": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "dashboard/dashboard.html",
        "dashboard/dashboard.js",
        "dashboard/dashboard.css",
        "dashboard/index.html",
        "password-reset/password-reset.html",
        "password-reset/password-reset.js",
        "quick-access/*",
        "shared/*",
        "lib/*"
      ],
      "matches": ["<all_urls>"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
